# Server Configuration
PORT=3000

# Redis configuration (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Object Storage Configuration (Cloudflare R2 or MinIO)
# For local dev with MinIO: http://localhost:9000
# For production R2: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=misskey-exports
# For MinIO, set R2_FORCE_PATH_STYLE to true. For Cloudflare R2, set to false.
R2_FORCE_PATH_STYLE=true

# Misskey Configuration
MISSKEY_INSTANCE_URL=https://papi.n1l.dev
MISSKEY_API_TOKEN=your_misskey_api_token_here
